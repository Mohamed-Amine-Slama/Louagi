{
  "expo": {
    "name": "Louagi",
    "slug": "louagi",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#031634"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.louagi.app",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to sign in to Louagi without your phone and password."
      }
    },
    "android": {
      "package": "com.louagi.app",
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_ANDROID_GOOGLE_MAPS_API_KEY"
        }
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C8102E"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      "expo-localization",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Use Face ID to sign in to Louagi without your phone and password."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Louagi uses your location while you drive so passengers can track their parcels in real time.",
          "isAndroidForegroundServiceEnabled": false,
          "isAndroidBackgroundLocationEnabled": false
        }
      ]
    ],
    "newArchEnabled": true
  }
}
