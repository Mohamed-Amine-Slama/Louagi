# ─── Backend ─────────────────────────────────────────────────────────────────
# URL of the Louagi Node backend (the server/ directory).
# Use your LAN IP (e.g. http://192.168.1.10:3000) when running Expo Go on a
# physical device — `localhost` from the phone won't resolve to your laptop.
EXPO_PUBLIC_API_URL=http://localhost:3000

# Docker/Expo only: set this to your LAN IP so Expo's QR code points phones
# back to your machine while Metro runs inside a container.
EXPO_HOST_IP=localhost

# Backend mode is the default. Set this to "true" only when you intentionally
# want the empty in-memory mock for offline UI work. Env vars are inlined at bundle build time, so
# restart Metro with `npx expo start -c` after changing this.
EXPO_PUBLIC_USE_MOCKS=false

# ─── Supabase (client-side: safe to ship in the bundle) ──────────────────────
# The MVP client uses the Node GraphQL backend for auth and business data.
# Keep these blank unless direct Supabase client features are added later.
#
# Find them at: Supabase dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxx
